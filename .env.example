# derrick — environment variables template.
#
# Copy this file to `.env` (gitignored) and fill in real values for local dev.
# Production deployments should use a secret manager, not a file.
#
# Two mechanisms are at play here:
#   1. SECRETS (private keys) — read directly by the bot from named env vars.
#   2. CONFIG OVERRIDES — variables prefixed `DERRICK__` override fields in
#      `config/default.toml`. Format: `DERRICK__<SECTION>__<FIELD>` (double
#      underscore as separator). Env always wins over TOML.
#
# ─────────────────────────────────────────────────────────────────────────────
# 1. SECRETS — never commit, never log
# ─────────────────────────────────────────────────────────────────────────────

# Private key of the operator account that signs `invoke_v3` calls to the
# executor contract. Hex-encoded `Felt` (with or without `0x` prefix).
# Read by `wiring::build_submitter` (crates/bot/src/wiring.rs:196). If unset,
# the submitter is disabled and the bot runs in detect-only mode (attempts
# still logged to the ledger, but never sent on-chain).
#
# In production: load from AWS Secrets Manager / Vault / SOPS, never a file.
OPERATOR_PRIVATE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# 2. CONFIG OVERRIDES — DERRICK__SECTION__FIELD
#
# Anything set here overrides the corresponding field in config/default.toml.
# Useful for: per-environment differences (dev/staging/prod), CI/CD injection,
# secrets that double as URLs (DATABASE_URL).
# ─────────────────────────────────────────────────────────────────────────────

# --- Starknet RPC + WebSocket endpoints ---
# Pathfinder/Juno HTTP RPC. Used by `chain::RpcProvider` for `call`, nonce
# queries, and tx-status polling. Local node strongly preferred for latency.
DERRICK__NETWORK__RPC_URL=http://localhost:9545

# Pathfinder/Juno WebSocket endpoint for event subscriptions. Drives the
# `WsWatcher` which feeds the pipeline. If absent, the bot starts but the
# watcher idles — no `PoolEvent` flows in, no opportunities detected.
DERRICK__NETWORK__WS_URL=ws://localhost:9545/ws

# Network selector. Named: `SN_MAIN`, `SN_SEPOLIA`. Or a raw hex felt for
# custom networks (devnets). Used for transaction signing (chain_id is part
# of the signed payload).
DERRICK__NETWORK__CHAIN_ID=SN_MAIN

# --- Database ---
# Postgres connection string for the ledger (attempts table). Also used by
# `sqlx::migrate!` on startup via `Ledger::run_migrations`.
DERRICK__DATABASE__URL=postgres://derrick:derrick@postgres:5432/derrick

# --- Executor contract + operator account ---
# Address of the deployed `ArbExecutor` Cairo contract that the bot calls
# `execute` on. Hex felt. If left as the placeholder `0x0`, submitter is
# disabled (same effect as missing OPERATOR_PRIVATE_KEY).
DERRICK__EXECUTOR__CONTRACT_ADDRESS=0x0

# Address of the account that owns the operator key. Hex felt. Must be a
# deployed Starknet account contract (Argent/Braavos/custom). The key in
# OPERATOR_PRIVATE_KEY must correspond to this account's signer.
DERRICK__EXECUTOR__OPERATOR_ACCOUNT_ADDRESS=0x0

# Paper-trading toggle. When `true`, the full pipeline runs (detect → size →
# simulate) but the final `submit` is suppressed; attempts get
# status=`paper_traded`. Use for pre-launch shadow runs against live RPC.
DERRICK__EXECUTOR__PAPER_TRADING=false

# --- Observability ---
# `tracing-subscriber` env-filter directive. Format: comma-separated
# `crate=level` pairs, plus a global default. Example:
#   `info,derrick=debug,sqlx=warn,tokio_tungstenite=info`
# Levels: trace, debug, info, warn, error, off.
DERRICK__OBSERVABILITY__LOG_LEVEL=info,derrick=debug

# Where the Prometheus exporter HTTP server binds. `host:port`. Scrape this
# from Prometheus to get `derrick_*` metrics (event counts, latency
# histograms, attempt-status counters).
DERRICK__OBSERVABILITY__METRICS_BIND=0.0.0.0:9090

# --- Risk parameters (rare to override via env — usually in TOML) ---
# How many consecutive failed/reverted/loss-making trades trip the circuit
# breaker. Once tripped, all trades pause for CIRCUIT_BREAKER_PAUSE_SECONDS.
# DERRICK__RISK__MAX_CONSECUTIVE_FAILURES=5

# Pause duration in seconds after the circuit breaker trips. The breaker
# auto-clears after this window; a positive-profit trade also resets the
# failure counter.
# DERRICK__RISK__CIRCUIT_BREAKER_PAUSE_SECONDS=600

# --- Strategy defaults (rare to override via env — usually in TOML) ---
# Fallback safety-margin in bps if not set per-`[spatial]` block.
# DERRICK__STRATEGY__SAFETY_MARGIN_BPS=30

# Fallback ternary-search iteration cap.
# DERRICK__STRATEGY__SIZER_ITERATIONS=40

# ─────────────────────────────────────────────────────────────────────────────
# 3. BUILD / DEV TOOLS — not read by the bot, used by ecosystem tooling
# ─────────────────────────────────────────────────────────────────────────────

# Path to the TOML config. Read by `clap` (crates/bot/src/main.rs:25). The
# CLI flag `--config <path>` overrides this. Default: `config/default.toml`.
DERRICK_CONFIG=config/default.toml

# Plain `DATABASE_URL` (no DERRICK prefix) is what `sqlx-cli`, `psql`, and
# the `sqlx::query!` compile-time macros read. The bot itself does NOT read
# this — it reads `DERRICK__DATABASE__URL`. Keep both in sync, or run
# `sqlx-cli` with `--database-url $DERRICK__DATABASE__URL`.
DATABASE_URL=postgres://derrick:derrick@postgres:5432/derrick

# Rust panic backtrace control. `1` = symbolicated, `full` = include
# unresolved frames. Off in production (small perf hit, large log spam).
RUST_BACKTRACE=1

# Standard tracing fallback. Used by `tracing-subscriber` ONLY if
# `DERRICK__OBSERVABILITY__LOG_LEVEL` is somehow not applied. In practice
# the TOML/DERRICK__ value wins; this is a belt-and-suspenders default.
RUST_LOG=info,derrick=debug
